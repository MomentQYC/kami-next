{
  "name": "mx-kami",
  "license": "GPL-3.0",
  "private": false,
  "version": "4.6.6",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "next-pwa",
        "next"
      ]
    },
    "patchedDependencies": {
      "@mx-space/api-client@1.18.1": "patches/@mx-space__api-client@1.18.1.patch",
      "react-message-popup@2.0.0-alpha.0": "patches/react-message-popup@2.0.0-alpha.0.patch"
    }
  },
  "bump": {
    "before": [
      "git pull --rebase",
      "ni"
    ],
    "changelog": true
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --cache --fix",
      "prettier --ignore-path ./.gitignore --write "
    ],
    "config.init.yaml": [
      "npm run gen-config && git add src/configs.default.ts"
    ]
  },
  "scripts": {
    "start": "npm run dev",
    "prebuild": "rimraf .next",
    "predev": "rimraf .next",
    "dev": "cross-env NODE_ENV=development next dev -p 2323 --webpack",
    "analyze": "cross-env NODE_ENV=production ANALYZE=true BUNDLE_ANALYZE=browser next build --webpack",
    "build": "cross-env NODE_ENV=production next build --webpack",
    "build:ci": "cross-env NODE_ENV=production CI=true next build --webpack",
    "lint": "eslint --ext .ts,.tsx --ignore-path .gitignore . --fix",
    "prod:pm2": "cross-env NODE_ENV=production pm2 restart ecosystem.config.js",
    "prod:pm2-alone": "cross-env NODE_ENV=production pm2 restart ecosystem.standalone.config.js",
    "prod:stop": "pm2 stop ecosystem.config.js",
    "prod:reload": "pm2 reload ecosystem.config.js",
    "gen-config": "node scripts/generate-default-configs.js",
    "gen-jsonschema": "npx ts-json-schema-generator --path 'src/types/config.ts' --type 'KamiConfig' > json-schema.json"
  },
  "browserslist": [
    "chrome >=94",
    "safari >=14",
    "last 2 Firefox versions"
  ],
  "dependencies": {
    "@floating-ui/react-dom": "2.1.6",
    "@formkit/auto-animate": "0.9.0",
    "@mx-space/api-client": "1.18.1",
    "@sentry/nextjs": "10.36.0",
    "axios": "1.13.2",
    "clsx": "2.1.1",
    "dayjs": "1.11.19",
    "devtools-detector": "2.0.25",
    "framer-motion": "12.29.0",
    "immer": "11.1.3",
    "js-cookie": "3.0.5",
    "lodash-es": "4.17.23",
    "markdown-escape": "2.0.0",
    "markdown-to-jsx": "npm:@innei/markdown-to-jsx@7.4.5-fork.4",
    "medium-zoom": "1.1.0",
    "mermaid": "11.12.2",
    "next": "16.1.4",
    "next-seo": "7.0.1",
    "next-suspense": "0.2.3",
    "randomcolor": "0.6.2",
    "react": "19.2.3",
    "react-countup": "6.5.3",
    "react-dom": "19.2.3",
    "react-error-boundary": "6.1.0",
    "react-intersection-observer": "10.0.2",
    "react-masonry-css": "1.0.16",
    "react-message-popup": "2.0.0-alpha.0",
    "react-shortcut-guide": "1.0.0",
    "react-smooth-number-counter": "npm:@reactify-components/smooth-number-counter",
    "react-toastify": "11.0.5",
    "react-use": "17.6.0",
    "remove-markdown": "0.6.3",
    "socket.io-client": "4.8.3",
    "swr": "2.3.8",
    "validator": "13.15.26",
    "xss": "1.0.15",
    "zustand": "5.0.10"
  },
  "devDependencies": {
    "@innei/eslint-config-react-ts": "0.15.0",
    "@innei/prettier": "1.0.0",
    "@next/bundle-analyzer": "16.1.4",
    "@sentry/webpack-plugin": "4.7.0",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/js-cookie": "3.0.6",
    "@types/lodash-es": "4.17.12",
    "@types/markdown-escape": "1.1.3",
    "@types/node": "25.0.10",
    "@types/randomcolor": "0.5.9",
    "@types/react": "19.2.9",
    "@types/react-color": "3.0.13",
    "@types/react-dom": "19.2.3",
    "@types/remove-markdown": "0.3.4",
    "@types/ua-parser-js": "0.7.39",
    "@types/validator": "13.15.10",
    "cross-env": "10.1.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "js-yaml": "4.1.1",
    "lint-staged": "16.2.7",
