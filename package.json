    "prettier": "3.8.1",
    "rimraf": "6.1.2",
    "tilg": "0.1.1",
    "typescript": "5.9.3",
    "windicss": "3.5.6",
    "windicss-webpack-plugin": "1.8.0",
    "zx": "8.8.5"
  },
  "resolutions": {
    "react-use": "17.6.0",
    "@types/react": "19.2.9"
  },
  "nextBundleAnalysis": {
    "budget": 358400,
    "budgetPercentIncreaseRed": 20,
    "showDetails": true
  },
  "packageManager": "pnpm@10.28.1"
}